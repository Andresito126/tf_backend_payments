# Database (compartida con tf_backend_main)
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=

NODE_ENV=development
PORT_SERVER=3003

# JWT — MISMO secret que tf_backend_main (solo validación de tokens)
JWT_ACCESS_SECRET=

# RabbitMQ
RABBITMQ_URL=amqp://localhost:5672

# Encryption — MISMAS claves que tf_backend_main (64 hex chars)
ENCRYPTION_KEY=
HMAC_SECRET=

# Conekta modo Pruebas (panel.conekta.com → Desarrolladores → API Keys)
CONEKTA_PRIVATE_KEY=
CONEKTA_API_BASE=https://api.conekta.io
CONEKTA_CURRENCY=MXN
TREASUREFLOW_FEE_RATE=0.05
